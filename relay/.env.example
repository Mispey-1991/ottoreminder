# Home Assistant
HA_URL=http://192.168.1.50:8123
HA_TOKEN=your_long_lived_access_token_here

# VAPID Keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=you@example.com

# Server
PORT=3000

# Deprecated: dose schedule is now configured via the settings panel
# and stored in /data/drug-config.json. These are only used on first
# boot if no drug-config.json exists, then migrated automatically.
# REMINDER_TIMES=08:00,12:00,17:00
# ESCALATION_TIME=20:00
